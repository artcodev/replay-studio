{
  "name": "replay-studio",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["apps/web"],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --watch",
    "dev:docker:config": "docker compose -f docker-compose.yml -f docker-compose.dev.yml config",
    "dev:docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:docker:migrate": "docker compose -f docker-compose.yml -f docker-compose.dev.yml run --rm migrate",
    "build": "npm run build --workspace apps/web",
    "test": "npm run test --workspace apps/web",
    "typecheck": "npm run typecheck --workspace apps/web"
  }
}
