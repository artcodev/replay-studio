DATABASE_URL=sqlite:///./replay-studio.db
REDIS_URL=
MATCH_DATA_PROVIDER=api-football
API_FOOTBALL_API_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
SPORTSDB_API_KEY=123
SPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
CORS_ORIGINS=http://localhost:5188,http://127.0.0.1:5188
MEDIA_ROOT=./data/media
MAX_VIDEO_BYTES=262144000
MAX_VIDEO_DURATION=60
# Analysis frames retain the video's native cadence. The calibration workspace
# chooses native or a lower scene-specific FPS explicitly.
RECONSTRUCTION_MODEL=yolo26m.pt
RECONSTRUCTION_DEVICE=cpu
RECONSTRUCTION_LEASE_TTL_SECONDS=180
RECONSTRUCTION_LEASE_HEARTBEAT_SECONDS=15
RECONSTRUCTION_RECOVERY_POLL_SECONDS=5
RECONSTRUCTION_RECOVERY_MAX_WORKERS=1
PIPELINE_LEASE_TTL_SECONDS=120
PIPELINE_LEASE_HEARTBEAT_SECONDS=10
PIPELINE_RECOVERY_POLL_SECONDS=2
PIPELINE_RECOVERY_MAX_WORKERS=2
PIPELINE_DEPENDENCY_POLL_SECONDS=2
BALL_DETECTION_BACKEND=dedicated-ultralytics
BALL_DETECTION_MODEL=./apps/api/models/football-ball-detection.pt
BALL_DETECTION_CONFIDENCE=0.05
BALL_DETECTION_IMAGE_SIZE=640
BALL_DETECTION_TILE_SIZE=640
BALL_DETECTION_TILE_OVERLAP=0.20
BALL_DETECTION_INFERENCE_BATCH_SIZE=8
BALL_DETECTION_CHECKPOINT_INTERVAL=4
BALL_DETECTION_FULL_SCAN_INTERVAL=5
BALL_DETECTION_ROI_REGION_COUNT=3
BALL_DETECTION_ROI_PADDING=320
BALL_DETECTION_NMS_IOU=0.10
BALL_DETECTION_MAX_CANDIDATES=12
BALL_ANALYSIS_FRAME_RATE=25
BALL_WASB_WORKER_URL=http://127.0.0.1:8092/v1/detections
BALL_WASB_TIMEOUT=120
BALL_DETECTION_FAILURE_POLICY=fallback
CALIBRATION_WORKER_URL=http://127.0.0.1:8090
CALIBRATION_WORKER_TIMEOUT=900
CALIBRATION_FRAME_WORKER_TIMEOUT=60
CALIBRATION_WORKER_BATCH_SIZE=2
# Safe tensor batch inside the pinned PnLCalib points+lines process. The API
# can still upload CALIBRATION_WORKER_BATCH_SIZE frames per HTTP request.
PNLCALIB_BATCH_SIZE=1
IDENTITY_WORKER_URL=http://127.0.0.1:8091
IDENTITY_WORKER_TIMEOUT=900
IDENTITY_WORKER_BATCH_SIZE=4
PERSON_DETECTION_WORKER_URL=
PERSON_DETECTION_WORKER_TIMEOUT=120
JERSEY_OCR_WORKER_URL=http://127.0.0.1:8093
JERSEY_OCR_WORKER_TIMEOUT=900
JERSEY_OCR_WORKER_BATCH_SIZE=32
JERSEY_OCR_PROVIDER=mmocr
JERSEY_OCR_DEVICE=cpu
JERSEY_OCR_PRELOAD=1
JERSEY_OCR_MODEL_BATCH_SIZE=32
JERSEY_OCR_MIN_CROP_WIDTH=20
JERSEY_OCR_MIN_CROP_HEIGHT=36
JERSEY_OCR_MIN_SHARPNESS=5
JERSEY_OCR_MIN_CONTRAST=4
JERSEY_OCR_MIN_CONFIDENCE=0.25
JERSEY_OCR_AMBIGUITY_MARGIN=0.05
JERSEY_OCR_CACHE_MAX_ENTRIES=4096
JERSEY_OCR_CACHE_TTL_SECONDS=86400
JERSEY_OCR_DOWNLOAD_MODELS=1
REID_DEVICE=cpu
REID_BATCH_SIZE=8
REID_PRELOAD=1
REID_MIN_CROP_WIDTH=16
REID_MIN_CROP_HEIGHT=30
REID_MIN_SHARPNESS=12
REID_CACHE_MAX_ENTRIES=4096
REID_CACHE_TTL_SECONDS=86400
REID_CACHE_WAIT_TIMEOUT_SECONDS=900
REID_DOWNLOAD_MODELS=1
WASB_DEVICE=cpu
WASB_PRELOAD=1
WASB_SCORE_THRESHOLD=0.5
